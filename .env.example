# OPIX — Environment Variables
# Copy to .env and fill in values

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=ganti-dengan-random-string-panjang

# ── AI Autorouter (urutan fallback: Groq → Gemini → Ollama → Anthropic) ──
# AI_PROVIDER=groq        # paksa pakai provider tertentu (opsional)

# Groq — GRATIS 14.400 req/hari | daftar: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant
# Model Groq lain: llama-3.3-70b-versatile | gemma2-9b-it | mixtral-8x7b-32768

# Google Gemini — GRATIS 1M token/hari | daftar: https://aistudio.google.com
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash
# Model Gemini lain: gemini-2.0-flash-exp | gemini-1.5-pro

# Ollama — LOKAL UNLIMITED | install: https://ollama.ai
# lalu jalankan: ollama pull llama3.1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Model Ollama lain: qwen2.5 | mistral | phi3 | gemma2

# Anthropic — BERBAYAR, last resort only
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5

# Database
DB_PATH=./opix.db

# File uploads
UPLOAD_DIR=./uploads

# Production
# FRONTEND_URL=https://opix.tiranyx.co.id
# NODE_ENV=production
